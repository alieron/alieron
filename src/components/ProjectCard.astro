---
import { languageColors } from "@/data/languageColors";
import type { Project } from "@/types";

type Props = {
  name: string;
  project?: Project;
};

const { name, project } = Astro.props;
const languages =
  project?.languages && project.languages.length > 0
    ? project.languages
    : project?.language
      ? [{ name: project.language, color: languageColors[project.language] ?? null, share: 1 }]
      : [];
const topics = project?.topics ?? [];
const isPrivate = project?.isPrivate ?? false;
const href = project && !isPrivate ? project.url : null;
const title = project?.name ?? name;
const description = project?.description ?? "-";
const website = project?.website ?? null;
---

<article
  class="vfd-panel group grid min-h-48 border border-line bg-panel/90 p-4 transition-colors duration-200 hover:border-line-strong hover:bg-panel-soft"
>
  <div class="flex h-full flex-col">
    <div class="mb-4 flex items-start justify-between gap-4">
      <div class="min-w-0">
        {
          href ? (
            <a
              class="vfd-glow break-words text-lg font-semibold text-accent transition hover:text-accent-strong"
              href={href}
              target="_blank"
              rel="noreferrer"
            >{title}</a>
          ) : (
            <h3 class="break-words text-lg font-semibold text-muted">{title}</h3>
          )
        }
      </div>
      {
        isPrivate && (
          <span class="shrink-0 border border-private-line bg-private-panel px-2 py-1 text-xs uppercase tracking-[0.1em] text-private shadow-[0_0_0.85rem_color-mix(in_srgb,var(--color-private)_12%,transparent)]">
            private
          </span>
        )
      }
    </div>

    <p class="text-[0.95rem] leading-6 text-muted">{description}</p>

    { 
      website && (
        <div class="mt-4 flex flex-wrap gap-2">
          <a
            class="vfd-glow text-sm font-semibold text-accent transition hover:text-accent-strong"
            href={website}
            target="_blank"
            rel="noreferrer"
            >
            {website}
          </a>
        </div>
      )
    }

    {
      topics.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {topics.map((topic) => (
            <span class="border border-topic-line bg-topic-panel px-2 py-1 text-sm text-topic shadow-[0_0_0.85rem_color-mix(in_srgb,var(--color-topic)_10%,transparent)]">
              {topic}
            </span>
          ))}
        </div>
      )
    }

    <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-2 pt-5 text-sm text-faint">
      {
        languages.map((language) => (
          <span class="inline-flex min-w-0 items-center gap-2">
            <span
              class="size-3 shrink-0"
              style={`background:${language.color ?? languageColors[language.name] ?? "#8ca6c2"}`}
            />
            <span>{language.name}</span>
            <!-- {language.share < 1 && <span class="text-xs">{Math.round(language.share * 100)}%</span>} -->
          </span>
        ))
      }
    </div>
  </div>
</article>
