---
import { languageColors } from "@/data/languageColors";
import type { Project } from "@/types";

type Props = {
  name: string;
  project?: Project;
};

const { name, project } = Astro.props;
const language = project?.language ?? null;
const languageColor = language ? (languageColors[language] ?? "#8ca6c2") : "#52708f";
const isPrivate = project?.isPrivate ?? false;
const href = project && !isPrivate ? project.url : null;
const title = project?.name ?? name;
const description = project?.description ?? "-";
---

<article
  class="group grid min-h-48 border border-line bg-panel/90 p-4 transition-colors duration-200 hover:border-line-strong hover:bg-panel-soft"
>
  <div class="flex h-full flex-col">
    <div class="mb-4 flex items-start justify-between gap-4">
      <div class="min-w-0">
        {
          href ? (
            <a
              class="break-words text-base font-semibold text-accent transition hover:text-accent-strong"
              href={href}
              target="_blank"
              rel="noreferrer"
            >
              {title}
            </a>
          ) : (
            <h3 class="break-words text-base font-semibold text-text">{title}</h3>
          )
        }
      </div>
      {
        isPrivate && (
          <span class="shrink-0 border border-line px-2 py-1 text-xs uppercase tracking-[0.1em] text-faint">
            private
          </span>
        )
      }
    </div>

    <p class="text-[0.95rem] leading-6 text-muted">{description}</p>

    <div class="mt-auto flex items-center gap-2 pt-5 text-sm text-faint">
      <span class="inline-flex min-w-0 items-center gap-2">
        {
          language && (
            <span class="size-3 shrink-0" style={`background:${languageColor}`}></span>
            <span>{language}</span>
          )
        }
      </span>
    </div>
  </div>
</article>
